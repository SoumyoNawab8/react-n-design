{
  "name": "react-n-design",
  "version": "0.4.0",
  "license": "MIT",
  "private": false,
  "description": "react-n-design: A modern, lightweight, and animated modern React component library.",
  "repository": {
    "type": "git",
    "url": "https://github.com/SoumyoNawab8/react-n-design.git"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "bin"
  ],
  "bin": {
    "react-n-design": "./bin/react-n-design.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./context": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./styles": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./styles/tokens.css": "./dist/styles/tokens.css",
    "./styles/print.css": "./dist/styles/print.css",
    "./styles/touch.css": "./dist/styles/touch.css",
    "./rsc": {
      "types": "./dist/rsc.d.ts",
      "import": "./dist/esm/rsc.js",
      "require": "./dist/cjs/rsc.js"
    }
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "npm run clean && npm run build:rollup && npm run build:css && npm run build:types:safe",
    "build:css": "node scripts/build-css.js",
    "build:rollup": "rollup -c",
    "build:types": "tsc --project tsconfig.build.json",
    "build:types:safe": "tsc --project tsconfig.build.json --noEmitOnError false || echo 'TypeScript warnings present but build continues'",
    "clean": "rimraf dist",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:vitest": "vitest run",
    "test:vitest:watch": "vitest",
    "build-storybook": "storybook build",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@storybook/addon-essentials": "^8.1.10",
    "@storybook/addon-interactions": "^8.1.10",
    "@storybook/addon-links": "^8.1.10",
    "@storybook/addon-styling": "^2.0.0",
    "@storybook/react": "^8.1.10",
    "@storybook/react-vite": "^8.6.14",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.3.1",
    "esbuild": "^0.28.0",
    "framer-motion": "^12.38.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "playwright": "^1.60.0",
    "react-icons": "^5.6.0",
    "react-window": "^1.8.11",
    "rimraf": "^5.0.5",
    "rollup": "^4.12.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "storybook": "^8.6.14",
    "styled-components": "^6.4.1",
    "axe-core": "^4.10.0",
    "jsdom": "^26.0.0",
    "ts-jest": "^29.1.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "react-icons": "^5.6.0",
    "react-window": "^1.8.10",
    "styled-components": "^6.4.1"
  },
  "sideEffects": false,
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "keywords": [
    "react",
    "n-design",
    "react-n-design",
    "ui",
    "neomorphism",
    "components",
    "design-system"
  ]
}
