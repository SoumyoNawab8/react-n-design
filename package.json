{
  "name": "react-n-design",
  "version": "1.2.0",
  "license": "MIT",
  "private": false,
  "description": "react-n-design: A modern, lightweight, and animated modern React component library.",
  "repository": {
    "type": "git",
    "url": "https://github.com/SoumyoNawab8/react-n-design.git"
  },
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "bin"
  ],
  "bin": {
    "react-n-design": "./bin/react-n-design.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./context": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./styles": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./styles/tokens.css": "./dist/styles/tokens.css",
    "./styles/print.css": "./dist/styles/print.css",
    "./styles/touch.css": "./dist/styles/touch.css",
    "./rsc": {
      "types": "./dist/rsc.d.ts",
      "import": "./dist/esm/rsc.js",
      "require": "./dist/cjs/rsc.js"
    }
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "npm run clean && npm run build:rollup && npm run build:css && npm run build:types:safe",
    "build:css": "node scripts/build-css.js",
    "build:rollup": "rollup -c",
    "build:types": "tsc --project tsconfig.build.json",
    "build:types:safe": "tsc --project tsconfig.build.json --noEmitOnError false || echo 'TypeScript warnings present but build continues'",
    "clean": "rimraf dist",
    "test:vitest": "vitest run",
    "test:vitest:watch": "vitest",
    "test:size": "npm run build && size-limit",
    "build-storybook": "storybook build",
    "size-limit": "size-limit",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.11.3",
    "@axe-core/react": "^4.11.3",
    "@biomejs/biome": "^2.4.15",
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@playwright/test": "^1.60.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "^8.6.14",
    "@storybook/addon-styling": "^2.0.0",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^15.0.7",
    "@testing-library/user-event": "^14.5.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.7",
    "axe-core": "^4.10.0",
    "esbuild": "^0.28.0",
    "framer-motion": "^12.38.0",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^17.0.5",
    "playwright": "^1.60.0",
    "react-icons": "^5.6.0",
    "react-window": "^1.8.11",
    "rimraf": "^5.0.5",
    "rollup": "^4.12.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "storybook": "^8.6.14",
    "styled-components": "^6.4.1",
    "typescript": "^6.0.3",
    "uuid": "^11.1.1",
    "vite": "^8.0.11",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "dompurify": "^3.4.5"
  },
  "peerDependencies": {
    "framer-motion": ">=12.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-window": ">=1.8.0",
    "styled-components": ">=6.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.{js,jsx,mjs,cjs,json,jsonc}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "sideEffects": false,
  "overrides": {
    "uuid": "^11.1.1"
  },
  "keywords": [
    "react",
    "react-n-design",
    "ui",
    "neomorphism",
    "neumorphism",
    "components",
    "design-system",
    "ai-components",
    "ai-chat",
    "chatbot-ui",
    "rsc",
    "react-server-components",
    "nextjs",
    "app-router",
    "zero-runtime-css",
    "css-variables",
    "styled-components",
    "tailwind-alternative",
    "accessible",
    "a11y",
    "wcag",
    "typescript",
    "command-palette",
    "spotlight",
    "cmdk"
  ]
}
